#!/usr/bin/env bash
set -oue pipefail
shopt -s nullglob

verbose=false
interactive=false

###################################
### Script Usage and Parameters ###
###################################

help_message() {
    echo "Usage: $0 [-h] [GRADING_DIRECTORY]"
    echo "Runner for local gradescope emulation."
    echo ""
    echo "options:"
    echo "-h                    Print this help message."
    echo "-v                    Verbose."
    echo "-i                    Interactive."
    echo "GRADING_DIRECTORY     Use instead of default."
    echo
}

while getopts ":h:v:i" o; do case "${o}" in
    h) help_message && exit ;;
    v) verbose=true ;;
    i) interactive=true ;;
    \?) printf "Invalid option: -%s\\n" "$OPTARG" && exit 1 ;;
esac done

shift $((OPTIND - 1));

SCRIPT_PATH="run_tests.py"
GRADING_DIR="${1:-submissions}"

###################################
### Functions ###
###################################

error() { printf "%s\n" "$1" >&2; exit 1; }

###################################
### Script ###
###################################

cur=$PWD
args=("$@")

function grade_routine {
  local student_dir="${1}"
  echo "${student_dir}..."
  mapfile -t -d '' student_files < <(find ${student_dir} -name '*.py' -print0)
  for file in "${student_files[@]}"; do cp "${file}" .; done
  python ${SCRIPT_PATH} ${student_dir}
  for file in "${student_files[@]}"; do rm "$(basename ${file})"; done
  grep score "${student_dir}/results.json" | tail -n 1
}

function dir_command {
  local student_dir="${1}"

  if ${interactive}; then
    read -p "Grade ${student_dir}? y/n: " grade_this_dir
    if [[ ${grade_this_dir} == "y" ]]; then
      grade_routine $student_dir
    else
      echo "Skipping to next dir."
    fi
  else
    grade_routine $student_dir
  fi
}

mapfile -t -d '' dirs < <(find ${GRADING_DIR} -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
for D in "${dirs[@]}"; do dir_command "${D}"; done
